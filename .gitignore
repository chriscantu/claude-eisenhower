.DS_Store

# User-specific config files � copy from *.example and fill in your values
# These contain account names, calendar names, and list names � never commit them
config/calendar-config.md
config/email-config.md
config/task-output-config.md

# Local task board and memory � personal data, not shared
TASKS.md
memory/

# Stakeholder graph � contains PII (real names, roles, contact info)
config/stakeholders.yaml

# Node.js � build artifacts and dependencies, never committed
scripts/node_modules/
tests/node_modules
tests/package-lock.json
dist/

# Plugin artifact � produced by npm run package, not committed
*.plugin
# Git worktrees - isolated development workspaces
.worktrees/

# Local backups — not committed
.backup/

# Personal reports — weekly reviews, feature requests
reports/

# Claude Code local settings
.claude/
