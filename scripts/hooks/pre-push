#!/usr/bin/env bash
# pre-push hook: blocks pushing a v* tag that doesn't match plugin.json version.
#
# Installed via: npm run install-hooks  (from the scripts/ directory)
# Source of truth: .claude-plugin/plugin.json → "version" field
#
# Git passes pushed refs on stdin, one per line:
#   <local-ref> <local-sha> <remote-ref> <remote-sha>
# e.g.: refs/tags/v1.2.0 abc123 refs/tags/v1.2.0 0000000000

REPO_ROOT="$(git rev-parse --show-toplevel)"
PLUGIN_JSON="$REPO_ROOT/.claude-plugin/plugin.json"

# Requires node; skip gracefully if not available
if ! command -v node &>/dev/null; then
  echo "⚠️  pre-push: node not found — skipping version check." >&2
  exit 0
fi

PLUGIN_VERSION=$(node -e "process.stdout.write(require('$PLUGIN_JSON').version)" 2>/dev/null)
if [ -z "$PLUGIN_VERSION" ]; then
  echo "⚠️  pre-push: could not read version from plugin.json — skipping check." >&2
  exit 0
fi

EXPECTED_TAG="v${PLUGIN_VERSION}"
FAILED=0

while read -r local_ref local_sha remote_ref remote_sha; do
  # Only care about version tags (refs/tags/v*)
  if [[ "$remote_ref" != refs/tags/v* ]]; then
    continue
  fi

  tag="${remote_ref#refs/tags/}"

  if [ "$tag" != "$EXPECTED_TAG" ]; then
    echo "❌ pre-push: tag '$tag' does not match plugin.json version '$PLUGIN_VERSION' (expected tag: $EXPECTED_TAG)" >&2
    FAILED=1
  fi
done

if [ "$FAILED" -eq 1 ]; then
  echo "" >&2
  echo "  Fix: bump the version in .claude-plugin/plugin.json to match your tag," >&2
  echo "  then commit and re-push. The tag and version must be in sync." >&2
  echo "" >&2
  exit 1
fi

exit 0
